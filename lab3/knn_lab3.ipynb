        "        f\"{auc_default:.4f}\"\n",
        "    ],\n",
        "    'Оптимальная (все признаки)': [\n",
        "        f\"{accuracy_best:.4f}\",\n",
        "        f\"{precision_best:.4f}\",\n",
        "        f\"{recall_best:.4f}\",\n",
        "        f\"{f1_best:.4f}\",\n",
        "        f\"{auc_best:.4f}\"\n",
        "    ],\n",
        "    'Финальная (очищенные признаки)': [\n",
        "        f\"{accuracy_final:.4f}\",\n",
        "        f\"{precision_final:.4f}\",\n",
        "        f\"{recall_final:.4f}\",\n",
        "        f\"{f1_final:.4f}\",\n",
        "        f\"{auc_final:.4f}\"\n",
        "    ]\n",
        "})\n",
        "\n",
        "display(final_comparison)\n",
        "\n",
        "# Визуализация сравнения\n",
        "fig, ax = plt.subplots(figsize=(14, 7))\n",
        "\n",
        "x = np.arange(len(final_comparison['Метрика']))\n",
        "width = 0.25\n",
        "\n",
        "metrics_default = [accuracy_default, precision_default, recall_default, f1_default, auc_default]\n",
        "metrics_best = [accuracy_best, precision_best, recall_best, f1_best, auc_best]\n",
        "metrics_final = [accuracy_final, precision_final, recall_final, f1_final, auc_final]\n",
        "\n",
        "bars1 = ax.bar(x - width, metrics_default, width, label='Исходная (K=3)', color='skyblue')\n",
        "bars2 = ax.bar(x, metrics_best, width, label='Оптимальная (все признаки)', color='lightgreen')\n",
        "bars3 = ax.bar(x + width, metrics_final, width, label='Финальная (очищенные)', color='salmon')\n",
        "\n",
        "ax.set_xlabel('Метрика')\n",
        "ax.set_ylabel('Значение')\n",
        "ax.set_title('Сравнение качества всех моделей')\n",
        "ax.set_xticks(x)\n",
        "ax.set_xticklabels(final_comparison['Метрика'])\n",
        "ax.legend()\n",

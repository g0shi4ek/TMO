        "# @title 24. Сравнение всех моделей\n",
        "# Создаем таблицу сравнения\n",
        "final_comparison = pd.DataFrame({\n",
        "    'Метрика': ['Accuracy', 'Precision', 'Recall', 'F1-score', 'ROC-AUC'],\n",
        "    'Исходная (K=3)': [\n",
        "        f\"{accuracy_default:.4f}\",\n",
        "        f\"{precision_default:.4f}\",\n",

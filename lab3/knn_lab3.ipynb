      "cell_type": "code",
      "source": [
        "# @title 14. GridSearchCV со Stratified K-Fold\n",
        "\n",
        "# GridSearch со Stratified K-Fold\n",
        "grid_strat = GridSearchCV(\n",
        "    knn, param_grid,\n",
        "    cv=StratifiedKFold(n_splits=5, shuffle=True, random_state=42),\n",

      "source": [
        "# @title 4. Анализ признаков\n",
        "print(\"АНАЛИЗ ПРИЗНАКОВ\")\n",
        "\n",
        "# Исключаем id, num и target из анализа признаков\n",
        "cols_to_exclude = ['id', 'num', 'target']\n",
        "\n",
        "# Разделяем признаки по типам\n",
        "num_cols = []\n",
        "cat_cols = []\n",
        "\n",
        "for col in df.columns:\n",
        "    if col in cols_to_exclude:\n",
        "        continue\n",
        "    if df[col].dtype in ['int64', 'float64']:\n",
        "        # Проверяем, является ли признак категориальным (мало уникальных значений)\n",
        "        if df[col].nunique() <= 10 and col not in ['age', 'trestbps', 'chol', 'thalch', 'oldpeak']:\n",
        "            cat_cols.append(col)\n",
        "        else:\n",
        "            num_cols.append(col)\n",
        "    else:\n",
        "        cat_cols.append(col)\n",
        "\n",
        "print(f\"Числовые признаки ({len(num_cols)}): {num_cols}\")\n",
        "print(f\"Категориальные признаки ({len(cat_cols)}): {cat_cols}\")\n",
        "\n",
        "# Визуализация распределений числовых признаков\n",
        "fig, axes = plt.subplots(2, 3, figsize=(15, 10))\n",
        "axes = axes.ravel()\n",
        "\n",
        "numeric_display = ['age', 'trestbps', 'chol', 'thalch', 'oldpeak', 'ca']\n",
